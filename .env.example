# Copy to .env and fill in. The app runs fine without this file (test mode + defaults).

# Public URL where the app is reachable by recipients' email clients.
# Required for open/click tracking on real sends (localhost is fine for local tests).
BASE_URL=http://127.0.0.1:5050

# Sender identity shown on outgoing email.
FROM_NAME=Lagniappe Foods
FROM_EMAIL=hello@lagniappefoods.com

# CAN-SPAM: a real physical mailing address is required in every email footer.
COMPANY_NAME=Lagniappe Foods
COMPANY_ADDRESS=123 Main St, Orange, NJ 07050

# Email provider. Leave blank for test mode (records sends without delivering).
# Get a free key at https://resend.com to send for real.
RESEND_API_KEY=
